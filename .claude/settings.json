{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -- docs/*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(npm install*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx prettier*)",
      "Bash(npx eslint*)",
      "Bash(ruff *)",
      "Bash(dotnet format*)",
      "Bash(python .cataforge/skills/*/scripts/*.py*)",
      "Bash(python .cataforge/scripts/framework/*.py*)",
      "Bash(python .cataforge/scripts/docs/*.py*)",
      "Bash(python .cataforge/integrations/penpot/setup_penpot.py --ensure)",
      "Bash(python -m pytest*)",
      "Bash(python -m pip install*)",
      "Bash(uv sync*)",
      "Bash(uv run *)",
      "Bash(uv pip install*)",
      "Bash(yarn install*)",
      "Bash(yarn run *)",
      "Bash(yarn test*)",
      "Bash(pnpm install*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test*)",
      "Bash(pnpm exec *)",
      "Bash(bun install*)",
      "Bash(bun run *)",
      "Bash(bun test*)",
      "Bash(bunx *)",
      "Bash(go mod *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(dotnet restore*)",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rmdir /s /q *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "block",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/guard_dangerous.py\""
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/log_agent_dispatch.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/validate_agent_result.py\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/lint_format.py\""
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/detect_correction.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/notify_done.py\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/notify_permission.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "observe",
            "command": "python \"$CLAUDE_PROJECT_DIR/.cataforge/hooks/session_context.py\""
          }
        ]
      }
    ]
  },
  "mcpServers": {},
  "enabledPlugins": {},
  "autoCompact": true
}
