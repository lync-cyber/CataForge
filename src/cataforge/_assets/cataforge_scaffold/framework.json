{
  "version": "0.1.0",
  "runtime_api_version": "1.0",
  "runtime": {
    "platform": "claude-code"
  },
  "description": "CataForge 统一框架配置。upgrade.source 为远程升级源配置（合并策略: 保留用户已配置值，补充新字段）；upgrade.state 为本地升级状态（始终保留）；features 和 migration_checks 为框架出厂配置（升级时全量覆盖）。",
  "upgrade": {
    "source": {
      "type": "github",
      "repo": "lync-cyber/CataForge",
      "branch": "main",
      "token_env": "GITHUB_TOKEN"
    },
    "state": {
      "last_commit": "",
      "last_version": "",
      "last_upgrade_date": ""
    }
  },
  "constants": {
    "MAX_QUESTIONS_PER_BATCH": 3,
    "MANUAL_REVIEW_CHECKPOINTS": ["pre_dev", "pre_deploy"],
    "EVENT_LOG_PATH": "docs/EVENT-LOG.jsonl",
    "EVENT_LOG_SCHEMA": ".cataforge/schemas/event-log.schema.json",
    "DOC_SPLIT_THRESHOLD_LINES": 300,
    "DOC_REVIEW_L2_SKIP_THRESHOLD_LINES": 200,
    "DOC_REVIEW_L2_SKIP_DOC_TYPES": ["brief", "prd-lite", "arch-lite", "dev-plan-lite", "changelog"],
    "TDD_LIGHT_LOC_THRESHOLD": 50,
    "SPRINT_REVIEW_MICRO_TASK_COUNT": 2,
    "RETRO_TRIGGER_SELF_CAUSED": 5
  },
  "features": {
    "tdd-engine": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": "development",
      "description": "TDD三阶段开发引擎 (RED→GREEN→REFACTOR)"
    },
    "doc-review": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "文档双层审计 (Layer 1脚本 + Layer 2 AI)"
    },
    "code-review": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": "development",
      "description": "代码双层审计 (Layer 1 lint + Layer 2 AI)"
    },
    "penpot-sync": {
      "min_version": "0.1.0",
      "auto_enable": false,
      "phase_guard": "ui_design",
      "description": "Penpot设计工具集成 (需设置 design-tool: penpot)"
    },
    "sprint-review": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": "development",
      "description": "Sprint完成度审查 — 计划vs实际对比、AC覆盖验证、范围偏移检测"
    },
    "change-guard": {
      "min_version": "0.1.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "变更守卫 — 分析变更请求与文档一致性，确保文档先行"
    },
    "correction-hook": {
      "min_version": "0.7.0",
      "auto_enable": true,
      "phase_guard": null,
      "description": "On-Correction Learning 放宽 — hook 自动捕获 AskUserQuestion option-override 信号"
    }
  },
  "migration_checks": [
    {
      "id": "mc-0.6.0-constants",
      "release_version": "0.6.0",
      "description": "COMMON-RULES.md 必须定义执行模式矩阵引用的配置常量",
      "type": "file_must_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": [
        "DOC_SPLIT_THRESHOLD_LINES",
        "DOC_REVIEW_L2_SKIP_THRESHOLD_LINES",
        "DOC_REVIEW_L2_SKIP_DOC_TYPES",
        "TDD_LIGHT_LOC_THRESHOLD",
        "SPRINT_REVIEW_MICRO_TASK_COUNT",
        "RETRO_TRIGGER_SELF_CAUSED"
      ]
    },
    {
      "id": "mc-0.6.0-no-legacy-constant",
      "release_version": "0.6.0",
      "description": "MIN_REVIEW_SOURCES 已被 RETRO_TRIGGER_SELF_CAUSED 取代",
      "type": "file_must_not_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": ["MIN_REVIEW_SOURCES"]
    },
    {
      "id": "mc-0.6.0-lite-templates",
      "release_version": "0.6.0",
      "description": "agile-lite / agile-prototype 模式所需模板齐全",
      "type": "dir_must_contain_files",
      "path": ".cataforge/skills/doc-gen/templates",
      "patterns": ["prototype/brief.md", "lite/prd-lite.md", "lite/arch-lite.md", "lite/dev-plan-lite.md"]
    },
    {
      "id": "mc-0.6.0-docgen-constant-ref",
      "release_version": "0.6.0",
      "description": "doc-gen SKILL.md 必须引用 DOC_SPLIT_THRESHOLD_LINES 而非硬编码 '500 行'",
      "type": "file_must_contain",
      "path": ".cataforge/skills/doc-gen/SKILL.md",
      "patterns": ["DOC_SPLIT_THRESHOLD_LINES"]
    },
    {
      "id": "mc-0.6.0-docgen-no-hardcoded-500",
      "release_version": "0.6.0",
      "description": "doc-gen SKILL.md 不得出现硬编码 '500 行'",
      "type": "file_must_not_contain",
      "path": ".cataforge/skills/doc-gen/SKILL.md",
      "patterns": ["500 行", "500行"]
    },
    {
      "id": "mc-0.7.0-session-context-simplified",
      "release_version": "0.7.0",
      "description": "session_context.py 不应再注入 additionalContext；职责简化为仅写 session_start 事件",
      "type": "file_must_not_contain",
      "path": ".cataforge/hooks/session_context.py",
      "patterns": ["_detect_pkg_env", "additionalContext"]
    },
    {
      "id": "mc-0.7.0-setup-emit-env",
      "release_version": "0.7.0",
      "description": "setup.py 必须提供 --emit-env-block 子命令供 orchestrator Bootstrap 填入 CLAUDE.md §执行环境",
      "type": "file_must_contain",
      "path": ".cataforge/scripts/framework/setup.py",
      "patterns": ["--emit-env-block", "build_env_block"]
    },
    {
      "id": "mc-0.7.0-detect-correction-registered",
      "release_version": "0.7.0",
      "description": "settings.json 必须注册 detect_correction 模块到 AskUserQuestion 匹配器",
      "type": "file_must_contain",
      "path": ".claude/settings.json",
      "patterns": ["detect_correction", "AskUserQuestion"],
      "requires_deploy": true
    },
    {
      "id": "mc-0.1.9-detect-review-flag-registered",
      "release_version": "0.1.9",
      "description": "settings.json 必须注册 detect_review_flag 模块（review-flag 通路自动化）",
      "type": "file_must_contain",
      "path": ".claude/settings.json",
      "patterns": ["detect_review_flag"],
      "requires_deploy": true
    },
    {
      "id": "mc-0.7.0-retro-threshold-relaxed",
      "release_version": "0.7.0",
      "description": "RETRO_TRIGGER_SELF_CAUSED 已从 2 放宽至 5 以补偿高频 option-override",
      "type": "file_must_contain",
      "path": ".cataforge/rules/COMMON-RULES.md",
      "patterns": ["RETRO_TRIGGER_SELF_CAUSED | 5"]
    },
    {
      "id": "mc-0.10.0-cataforge-dir",
      "release_version": "0.10.0",
      "description": ".cataforge/ 目录必须存在且包含核心文件",
      "type": "dir_must_contain_files",
      "path": ".cataforge",
      "patterns": [
        "framework.json",
        "PROJECT-STATE.md",
        "platforms/claude-code/profile.yaml",
        "hooks/hooks.yaml"
      ]
    },
    {
      "id": "mc-0.10.0-override-mechanism",
      "release_version": "0.10.0",
      "description": "dispatch-prompt.md 必须包含 OVERRIDE 标记",
      "type": "file_must_contain",
      "path": ".cataforge/skills/agent-dispatch/templates/dispatch-prompt.md",
      "patterns": ["OVERRIDE:dispatch_syntax", "OVERRIDE:return_format"]
    },
    {
      "id": "mc-0.10.0-capability-ids",
      "release_version": "0.10.0",
      "description": "源 AGENT.md 必须使用能力标识符",
      "type": "file_must_not_contain",
      "path": ".cataforge/agents/orchestrator/AGENT.md",
      "patterns": ["tools: Read"]
    }
  ]
}
