# ============================================================================
#  CataForge 环境配置示例
#  复制为 .env 后根据实际情况修改
#  用法: cp .env.example .env && vi .env
# ============================================================================

# --- GitHub Token ---
# 用于远程升级检测 (upgrade.py check/upgrade 命令)
# 生成地址: https://github.com/settings/tokens
# 私有仓库必须配置；公开仓库可选（避免 API 限流）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- 网络代理 ---
# 用于受限网络环境下的 git clone / npm install / GitHub API 调用
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.example.com

# --- Penpot MCP (可选，仅启用 Penpot 设计集成时需要) ---
# PENPOT_BASE_URL=http://localhost:9001
# PENPOT_MCP_DIR=$HOME/penpot-mcp
# PENPOT_MCP_SERVER_PORT=4401
# PENPOT_MCP_WEBSOCKET_PORT=4402
